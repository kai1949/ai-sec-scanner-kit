{
  "$schema": "https://opencode.ai/config.json",
  // "plugin": ["opencode-openai-codex-auth"],
  // "enterprise": {
  //   "url": "https://enterprise.dev.opencode.ai",
  // },
  "instructions": ["STYLE_GUIDE.md"],
  // 工具权限配置
  "permission": {
    // 文件操作
    "read": "allow",
    "edit": "allow",
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    // LSP 代码智能（实验性功能）
    "lsp": "allow",
    // 网络访问需要确认
    "webfetch": "ask",
    // bash 命令权限（允许所有命令）
    "bash": {
      "*": "allow"
    },
    // 任务管理
    "todowrite": "allow",
    "todoread": "allow",
    // 用户交互
    "question": "allow"
  },
  "provider": {
    "opencode": {
      "options": {},
    },
  },
  "tools": {
    "github-triage": false,
    "github-pr-search": false,
  },
}
